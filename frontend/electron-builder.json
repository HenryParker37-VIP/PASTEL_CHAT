{
  "appId": "com.pastelchat.app",
  "productName": "PastelChat",
  "copyright": "Copyright © 2024 PastelChat",
  "files": [
    "build/**/*",
    "node_modules/**/*",
    "public/electron.js",
    "public/preload.js"
  ],
  "directories": {
    "buildResources": "public",
    "output": "dist"
  },
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] },
      { "target": "portable", "arch": ["x64"] }
    ],
    "icon": "public/icon.png"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "PastelChat"
  },
  "publish": {
    "provider": "github",
    "owner": "YOUR_GITHUB_USERNAME",
    "repo": "pastel-chat"
  }
}
